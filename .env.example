# .env.example — salin ke .env.local dan isi nilai sebenarnya.

# URL backend Laravel (ginnva-api)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Google Analytics 4 — Measurement ID (format: G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=

# Sentry — error tracking. Kosongkan untuk menonaktifkan.
# Dapatkan dari: sentry.io → Project Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# Opsional — hanya diperlukan untuk upload sourcemap otomatis saat build
# (supaya stack trace di Sentry menunjuk ke source asli, bukan kode minified).
# Dapatkan dari: sentry.io → Settings → Auth Tokens
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=